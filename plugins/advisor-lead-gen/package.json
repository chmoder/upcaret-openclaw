{
  "name": "advisor-lead-gen",
  "version": "4.2.0",
  "description": "SEC IAPD download (extract-advisors.js) + OpenClaw agent-to-agent enrichment (IDENTITY.md orchestrator)",
  "type": "module",
  "main": "scripts/extract-advisors.js",
  "files": [
    "openclaw.plugin.json",
    "plugin-entry.ts",
    "ARCHITECTURE.md",
    "IDENTITY.md",
    "README.md",
    "SKILL.md",
    "agents/",
    "references/",
    "scripts/bootstrap.js",
    "scripts/check-skill-layout.js",
    "scripts/db-init.js",
    "scripts/db.js",
    "scripts/engine-db.js",
    "scripts/finding-types.js",
    "scripts/enqueue-enrich.js",
    "scripts/extract-advisors.js",
    "scripts/feed.js",
    "scripts/next-advisor.js",
    "scripts/record-enrichment.js",
    "scripts/reset-queue.js",
    "scripts/save-enrichment.js",
    "scripts/status-dashboard.js"
  ],
  "scripts": {
    "extract": "node scripts/extract-advisors.js",
    "status": "node scripts/status-dashboard.js",
    "db:init": "node scripts/db-init.js",
    "bootstrap": "node scripts/bootstrap.js",
    "test": "node scripts/check-skill-layout.js",
    "reset:queue": "node scripts/reset-queue.js",
    "next": "node scripts/next-advisor.js",
    "enqueue": "node scripts/enqueue-enrich.js",
    "feed": "node scripts/feed.js"
  },
  "keywords": [
    "financial-services",
    "sec-iapd",
    "openclaw",
    "advisor-enrichment"
  ],
  "author": "OpenClaw",
  "license": "MIT",
  "dependencies": {},
  "engines": {
    "node": ">=22.5.0"
  },
  "openclaw": {
    "extensions": [
      "./plugin-entry.ts"
    ]
  },
  "env": {
    "BRAVE_API_KEY": {
      "required": true,
      "description": "Brave Search API key for web discovery (enrichment). Set via OpenClaw Settings \u2192 Environment variables or openclaw config set env.BRAVE_API_KEY"
    },
    "ANTHROPIC_API_KEY": {
      "required": false,
      "description": "Optional; depends on OpenClaw/model configuration"
    },
    "FIRECRAWL_API_KEY": {
      "required": false,
      "description": "Optional Firecrawl API key for URL scraping / web_fetch when your OpenClaw gateway is configured to use Firecrawl. Set via Settings → Environment variables or openclaw config set env.FIRECRAWL_API_KEY"
    },
    "HUNTER_API_KEY": {
      "required": false,
      "description": "Optional email verification"
    }
  }
}
